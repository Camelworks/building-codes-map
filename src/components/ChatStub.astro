---
// Floating LLM chat panel — UI only, no backend wired up.
// When wired, the input handler would POST to /api/chat with the active region + message.
---

<button id="bcm-chat-toggle" type="button" class="fixed bottom-5 right-5 z-30 flex items-center gap-2 rounded-full bg-teal-700 px-4 py-3 text-sm font-medium text-white shadow-xl ring-1 ring-teal-900/10 hover:bg-teal-800" aria-label="Open AI chat about codes">
  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 12a8 8 0 0 1-11.6 7.2L4 21l1.8-5.4A8 8 0 1 1 21 12Z"/>
  </svg>
  Ask about codes
</button>

<section id="bcm-chat-panel" class="glass fixed bottom-5 right-5 z-30 hidden h-[520px] max-h-[80vh] w-[380px] max-w-[92vw] flex-col overflow-hidden rounded-2xl shadow-2xl">
  <header class="flex items-center justify-between border-b border-slate-200 px-4 py-3">
    <div>
      <h3 class="text-sm font-semibold text-slate-900">Ask about codes</h3>
      <p class="text-[11px] text-slate-500" id="bcm-chat-context">No region selected</p>
    </div>
    <button id="bcm-chat-close" type="button" class="rounded-full p-1.5 text-slate-500 hover:bg-slate-100 hover:text-slate-900" aria-label="Close chat">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>
  </header>

  <div id="bcm-chat-log" class="flex-1 space-y-3 overflow-y-auto p-4 text-sm">
    <div class="rounded-2xl rounded-tl-sm bg-slate-100 px-3 py-2 text-slate-700">
      Hi 👋 Pick a region and ask a question like <em>"what are the staircase requirements for a 3-storey house?"</em>
      <br><br>
      <span class="text-xs text-slate-500">This chat is a UI placeholder — no LLM is wired up yet.</span>
    </div>
  </div>

  <form id="bcm-chat-form" class="flex items-end gap-2 border-t border-slate-200 p-3">
    <textarea id="bcm-chat-input" rows="1" placeholder="Ask a question…" class="flex-1 resize-none rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm text-slate-800 placeholder:text-slate-400 focus:border-teal-600 focus:outline-none focus:ring-1 focus:ring-teal-600"></textarea>
    <button type="submit" class="rounded-xl bg-teal-700 px-3 py-2 text-sm font-medium text-white hover:bg-teal-800 disabled:cursor-not-allowed disabled:opacity-50">Send</button>
  </form>
</section>

<script>
  const toggle = document.getElementById('bcm-chat-toggle') as HTMLButtonElement;
  const panel = document.getElementById('bcm-chat-panel') as HTMLElement;
  const closeBtn = document.getElementById('bcm-chat-close') as HTMLButtonElement;
  const form = document.getElementById('bcm-chat-form') as HTMLFormElement;
  const input = document.getElementById('bcm-chat-input') as HTMLTextAreaElement;
  const log = document.getElementById('bcm-chat-log') as HTMLElement;
  const ctx = document.getElementById('bcm-chat-context') as HTMLElement;

  let activeRegion: { name: string } | null = null;

  function escape(s: string) {
    return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));
  }

  function open() {
    panel.classList.remove('hidden');
    panel.classList.add('flex');
    toggle.classList.add('hidden');
    input.focus();
  }

  function close() {
    panel.classList.add('hidden');
    panel.classList.remove('flex');
    toggle.classList.remove('hidden');
  }

  function appendUser(text: string) {
    const el = document.createElement('div');
    el.className = 'ml-auto max-w-[85%] rounded-2xl rounded-tr-sm bg-teal-700 px-3 py-2 text-white';
    el.textContent = text;
    log.appendChild(el);
    log.scrollTop = log.scrollHeight;
  }

  function appendBot(html: string) {
    const el = document.createElement('div');
    el.className = 'mr-auto max-w-[85%] rounded-2xl rounded-tl-sm bg-slate-100 px-3 py-2 text-slate-700';
    el.innerHTML = html;
    log.appendChild(el);
    log.scrollTop = log.scrollHeight;
  }

  toggle.addEventListener('click', open);
  closeBtn.addEventListener('click', close);

  window.addEventListener('bcm:region', (e: Event) => {
    activeRegion = (e as CustomEvent).detail;
    ctx.textContent = activeRegion ? `Region: ${activeRegion.name}` : 'No region selected';
  });

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const text = input.value.trim();
    if (!text) return;
    appendUser(text);
    input.value = '';
    setTimeout(() => {
      const where = activeRegion ? ` for ${escape(activeRegion.name)}` : '';
      appendBot(
        `<p class="text-slate-700">I'd answer your question about <strong>${escape(text)}</strong>${where} — but the LLM backend isn't connected yet.</p>` +
          `<p class="mt-2 text-xs text-slate-500">To wire this up: add an <code>/api/chat</code> endpoint that takes the active region's documents as context and calls Claude / OpenAI / etc.</p>`
      );
    }, 280);
  });

  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      form.requestSubmit();
    }
  });
</script>
