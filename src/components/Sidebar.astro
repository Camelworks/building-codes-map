---
// Slide-in sidebar that displays building codes for the currently selected region.
// Listens for `bcm:region` events on window with { code, name, regulator, authority, indexUrl, documents }.
// Listens for `bcm:close-sidebar` to close.
---

<aside id="bcm-sidebar" class="glass fixed right-0 top-0 z-20 flex h-full w-full max-w-md translate-x-full flex-col border-l shadow-2xl transition-transform duration-300 ease-out">
  <header class="flex items-start justify-between gap-3 border-b border-slate-200 p-5">
    <div>
      <p class="text-xs font-medium uppercase tracking-wider text-teal-700" id="bcm-sb-region">—</p>
      <h2 class="mt-1 text-lg font-semibold text-slate-900" id="bcm-sb-regulator">Select a region on the map</h2>
      <p class="mt-1 text-xs text-slate-500" id="bcm-sb-authority"></p>
    </div>
    <button id="bcm-sb-close" type="button" class="rounded-full p-1.5 text-slate-500 hover:bg-slate-100 hover:text-slate-900" aria-label="Close panel">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>
  </header>

  <div class="border-b border-slate-200 px-5 py-3">
    <a id="bcm-sb-index" href="#" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-xs font-medium text-teal-700 hover:text-teal-900">
      Official index
      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M7 17 17 7M8 7h9v9"/>
      </svg>
    </a>
  </div>

  <ol id="bcm-sb-list" class="flex-1 divide-y divide-slate-100 overflow-y-auto"></ol>

  <footer class="border-t border-slate-200 px-5 py-3 text-[11px] text-slate-500">
    Links go directly to official government sources. Always confirm the current version applies to your project.
  </footer>
</aside>

<script>
  const sb = document.getElementById('bcm-sidebar') as HTMLElement;
  const region = document.getElementById('bcm-sb-region') as HTMLElement;
  const regulator = document.getElementById('bcm-sb-regulator') as HTMLElement;
  const authority = document.getElementById('bcm-sb-authority') as HTMLElement;
  const index = document.getElementById('bcm-sb-index') as HTMLAnchorElement;
  const list = document.getElementById('bcm-sb-list') as HTMLOListElement;
  const closeBtn = document.getElementById('bcm-sb-close') as HTMLButtonElement;

  function escape(s: string) {
    return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));
  }

  function open() {
    sb.classList.remove('translate-x-full');
  }

  function close() {
    sb.classList.add('translate-x-full');
  }

  window.addEventListener('bcm:region', (e: Event) => {
    const d = (e as CustomEvent).detail;
    region.textContent = d.name;
    regulator.textContent = d.regulator;
    authority.textContent = d.authority;
    index.href = d.indexUrl;
    list.innerHTML = (d.documents as any[])
      .map(
        (doc) => `
        <li>
          <a href="${escape(doc.url)}" target="_blank" rel="noopener" class="group flex items-start gap-3 px-5 py-3 hover:bg-slate-50">
            <span class="mt-0.5 inline-flex h-6 min-w-[2rem] items-center justify-center rounded-md bg-teal-50 px-1.5 text-[11px] font-semibold tracking-wide text-teal-700">${escape(doc.code)}</span>
            <span class="flex-1">
              <span class="block text-sm font-medium text-slate-900 group-hover:text-teal-800">${escape(doc.title)}</span>
              <span class="mt-0.5 block text-xs leading-relaxed text-slate-500">${escape(doc.summary)}</span>
            </span>
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-1 shrink-0 text-slate-300 group-hover:text-teal-700">
              <path d="M7 17 17 7M8 7h9v9"/>
            </svg>
          </a>
        </li>`
      )
      .join('');
    open();
  });

  window.addEventListener('bcm:close-sidebar', close);
  closeBtn.addEventListener('click', close);
</script>
